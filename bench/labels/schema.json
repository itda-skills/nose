{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nose query-family labels",
  "description": "Ground truth for the refactoring-candidate product metric. See RUBRIC.md.",
  "type": "object",
  "required": ["schema_version", "families"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["family_id", "repo", "members", "channel", "worthy", "reason", "scope", "confidence", "labeler"],
        "properties": {
          "family_id": { "type": "string", "description": "FNV-1a over sorted member (file,start_line,end_line)" },
          "repo": { "type": "string" },
          "members": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["file", "start_line", "end_line"],
              "properties": {
                "file": { "type": "string" },
                "start_line": { "type": "integer" },
                "end_line": { "type": "integer" },
                "name": { "type": ["string", "null"] }
              }
            }
          },
          "channel": { "enum": ["structural", "contiguous", "both"] },
          "worthy": { "type": "boolean" },
          "reason": {
            "enum": [
              "extract-helper", "extract-base", "extract-data-table", "parameterize",
              "parallel-by-design", "coincidental-shape", "type-def", "generated", "trivial"
            ]
          },
          "scope": { "enum": ["prod", "test", "mixed"] },
          "confidence": { "enum": ["high", "medium", "low"] },
          "note": { "type": "string" },
          "labeler": { "enum": ["draft", "panel", "human"] }
        }
      }
    }
  }
}
