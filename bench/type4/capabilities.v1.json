{
  "schema_version": "0.1.0",
  "semantic_axes": {
    "collection_empty_check": "Static collection emptiness and non-emptiness checks can be proven through fixed receiver coordinates and length-zero or named-predicate forms.",
    "immutable_binding": "Local immutable aliases and single-assignment module constants can be used as proof facts.",
    "import_identity": "Static import bindings can prove a callee/value identity by module coordinate and exported symbol.",
    "literal_collection_membership": "Static literal collection membership predicates can be proven through fixed element and literal collection coordinates.",
    "nullish_default": "Nullish coalescing and explicit null/undefined guards can prove the same defaulting behavior when the fallback condition is fixed.",
    "own_property_guard": "Static JavaScript own-property guards can prove the same key-presence check when receiver and key coordinates are fixed.",
    "projection_identity": "Static field/property projection can prove a value identity when the receiver and projected coordinate are fixed.",
    "proven_callee_identity": "Opaque calls are strict only when the callee identity is local, immutable, or a safe same-file function binding.",
    "record_shape_guard": "Static JavaScript record guards can prove non-null object and non-array shape checks when all required clauses are present.",
    "string_prefix_suffix": "Case-sensitive string prefix and suffix predicates can be proven through fixed receiver and literal affix coordinates.",
    "table_access": "Literal table construction and static key/index access retain behavior-defining key identity.",
    "unsafe_boundary": "Unproven free globals, repeated assignment, spread/unpack, dynamic import, and reflection boundaries are excluded from exact semantic reporting."
  },
