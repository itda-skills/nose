{
  "schema_version": "0.1.0",
  "semantic_axes": {
    "collection_empty_check": "Static collection emptiness and non-emptiness checks can be proven through fixed receiver coordinates and length-zero or named-predicate forms.",
    "immutable_binding": "Local immutable aliases and single-assignment module constants can be used as proof facts.",
    "import_identity": "Static import bindings can prove a callee/value identity by module coordinate and exported symbol.",
    "java_integer_low_bit_toggle": "Java primitive integer parity branches that add one to even values and subtract one from odd values can prove the same low-bit toggle as `x ^ 1`.",
    "java_statically_false_loop": "Java loops with a pure short-circuit entry guard proven false before the first iteration have unreachable bodies.",
    "literal_collection_membership": "Static literal, literal-factory, and typed dynamic collection membership predicates can be proven through fixed element and collection receiver coordinates.",
    "literal_map_default_lookup": "Static literal-map or literal-factory lookup with a fallback can be proven through fixed map, key, and default coordinates.",
    "map_default_lookup": "Typed map lookup with a fallback can be proven through fixed map receiver, key, and fallback coordinates when the surface exposes map-key presence and lookup facts.",
    "map_key_membership": "Map key-presence predicates can be proven through fixed map receiver and key coordinates, including explicit typed map receiver facts.",
    "null_presence_predicate": "Null, none, nil, and option presence predicates can be proven through fixed value coordinates and explicit absence/presence direction.",
    "numeric_minmax_abs": "Scalar absolute-value and two-way min/max builtins or proven numeric methods can be proven through fixed numeric value coordinates and equivalent conditional idioms.",
    "nullish_default": "Nullish coalescing, option defaulting, and explicit null/undefined guards can prove the same defaulting behavior when the value and fallback coordinates are fixed.",
    "own_property_guard": "Static JavaScript own-property guards can prove the same key-presence check when receiver and key coordinates are fixed.",
    "projection_identity": "Static field/property projection can prove a value identity when the receiver and projected coordinate are fixed.",
    "python_docstring_noop": "Python function and class docstrings are metadata-only static string statements and do not affect callable behavior.",
    "proven_callee_identity": "Opaque calls are strict only when the callee identity is local, immutable, or a safe same-file function binding.",
    "record_shape_guard": "Static JavaScript record guards can prove non-null object and non-array shape checks when all required clauses are present.",
    "string_prefix_suffix": "Case-sensitive string prefix and suffix predicates can be proven through fixed receiver and literal affix coordinates.",
    "table_access": "Literal table construction and static key/index access retain behavior-defining key identity.",
    "total_order_compare": "Strict total-order three-way comparators can be proven through fixed ordered value coordinates and equivalent guard-return or ternary sign forms.",
    "unsafe_boundary": "Unproven free globals, repeated assignment, spread/unpack, dynamic import, and reflection boundaries are excluded from exact semantic reporting."
  },
